@using System.IO
@using Microsoft.AspNetCore.Components
@inject HttpClient Http

<div class="setup-panel">
    <div class="setup-card">
        <h2 class="mb-3">Get Started</h2>
        <p class="text-muted mb-4">
            Select a preset or upload your own JSON file to begin editing.
            <a href="/help" target="_blank">Need help?</a>
        </p>

        <div class="mb-4">
            <label class="form-label fw-bold">Select a preset</label>
            <select class="form-select" @onchange="LoadPreset">
                <option value="">-- Select a preset --</option>
                @foreach (var preset in _presetFiles)
                {
                    <option value="@preset.Path">@preset.Name</option>
                }
            </select>
        </div>

        <div class="divider">
            <span>or</span>
        </div>

        <div class="mt-4">
            <label class="form-label fw-bold">Upload your own JSON file</label>
            <InputFile OnChange="UploadJsonFile" accept=".json" class="form-control" />
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnPresetLoaded { get; set; }
    [Parameter] public EventCallback<string> OnFileUploaded { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private record PresetEntry(string Name, string Path);

    private List<PresetEntry> _presetFiles =
    [
        new("Empty", "presets/Empty.json"),
        new("Vanilla", "presets/Vanilla.json"),
        new("Vanilla 1.3.6f1", "presets/Vanilla 1.3.6f1.json"),
        new("German Vehicle Pack", "presets/German Vehicle Pack.json"),
        new("Realistic Global", "presets/Realistic Global.json"),
        new("Vancouver, Canada", "presets/Vancouver, Canada.json"),
        new("Vanilla Rebalance", "presets/Vanilla Rebalance.json"),
        new("Japan", "presets/Japan.json")
    ];

    protected override Task OnInitializedAsync()
    {
        Telemetry.EnterWebsite();
        return Task.CompletedTask;
    }

    private async Task LoadPreset(ChangeEventArgs e)
    {
        var selectedPreset = e.Value?.ToString();
        if (string.IsNullOrEmpty(selectedPreset)) return;

        try
        {
            var presetJson = await Http.GetStringAsync(selectedPreset);
            Telemetry.StartWithTemplate(selectedPreset);
            await OnPresetLoaded.InvokeAsync(presetJson);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading preset {selectedPreset}: {ex.Message}");
        }
    }

    private async Task UploadJsonFile(InputFileChangeEventArgs e)
    {
        var uploadedFile = e.File;
        await using var stream = uploadedFile.OpenReadStream(10 * 1024 * 1024);
        using var reader = new StreamReader(stream);
        var json = await reader.ReadToEndAsync();
        await OnFileUploaded.InvokeAsync(json);
    }
}
