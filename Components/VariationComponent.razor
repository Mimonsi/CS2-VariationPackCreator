@using Microsoft.AspNetCore.Components
@using VariationPackCreator.Models

<div class="variation-card">
    <div class="variation-header">
        <div class="variation-meta">
            @if (!string.IsNullOrEmpty(VariationChance))
            {
                <span class="variation-chance badge bg-secondary">@VariationChance</span>
            }
            <div class="probability-group">
                <label for="probability-@GetHashCode()">Weight</label>
                <input type="number" id="probability-@GetHashCode()"
                       @bind-value="ProbabilityInput"
                       @bind-value:event="oninput"
                       min="0" max="255" step="1"
                       class="form-control form-control-sm probability-input @ValidationClass" />
            </div>
        </div>
        <button @onclick="OnRemoveVariationClick" class="btn btn-sm btn-outline-danger" title="Remove variation">
            &times;
        </button>
    </div>

    @if (!string.IsNullOrEmpty(ValidationMessage))
    {
        <div class="alert alert-warning alert-sm mt-1 mb-0 py-1 px-2">@ValidationMessage</div>
    }

    <div class="variation-colors">
        <ColorInputComponent Label="Color 1" Color="@Variation.Color1" />
        <ColorInputComponent Label="Color 2" Color="@Variation.Color2" />
        <ColorInputComponent Label="Color 3" Color="@Variation.Color3" />
    </div>
</div>

@code {
    [Parameter] public required Variation Variation { get; set; }
    [Parameter] public required EventCallback OnRemoveVariationClick { get; set; }
    [Parameter] public required string VariationChance { get; set; }
    [Parameter] public required EventCallback OnVariationProbabilityChange { get; set; }

    private string? ValidationMessage { get; set; }
    private string ValidationClass { get; set; } = string.Empty;

    private int ProbabilityInput
    {
        get => Variation.Probability;
        set
        {
            if (value > 255)
            {
                ValidationMessage = "Max 255. Add another variation for higher combined weight.";
                ValidationClass = "is-invalid";
                Variation.Probability = 255;
            }
            else
            {
                ValidationMessage = null;
                ValidationClass = string.Empty;
                Variation.Probability = value;
                OnVariationProbabilityChange.InvokeAsync();
            }
        }
    }
}
