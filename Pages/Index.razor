@page "/"
@using System.Text.Json
@using VariationPackCreator.Models
@using VariationPackCreator.Components
@inject HttpClient Http
@inject IJSRuntime JsRuntime

@if (ShowSetup)
{
    <SetupPanel OnPresetLoaded="LoadJson" OnFileUploaded="LoadJson" OnClose="() => ShowSetup = false" ErrorMessage="@ErrorMessage" />
}
else if (CurrentPack is not null && VanillaPack is not null)
{
    <div class="toolbar">
        <button class="btn btn-outline-danger btn-sm" @onclick="ConfirmStartFromScratch">
            Start from Scratch
        </button>
        <button class="btn btn-primary" @onclick="DownloadPack">
            Download Pack
        </button>
    </div>

    <div class="pack-editor">
        <PackComponent Pack="@CurrentPack" VanillaPack="@VanillaPack" />
    </div>

    <script suppress-error="BL9992">
        function downloadJson(jsonData, fileName) {
            const blob = new Blob([jsonData], { type: 'application/json' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }
    </script>
}

@code {
    private Pack? CurrentPack { get; set; }
    private Pack? VanillaPack { get; set; }
    private bool ShowSetup = true;
    private string? ErrorMessage { get; set; }

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        Converters = { new ColorConverter() },
        PropertyNameCaseInsensitive = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailablePrefabs();
    }

    private async Task LoadAvailablePrefabs()
    {
        try
        {
            var json = await Http.GetStringAsync("presets/Vanilla.json");
            VanillaPack = JsonSerializer.Deserialize<Pack>(json, JsonOptions);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading vanilla prefabs: {ex.Message}");
        }
    }

    private async Task LoadJson(string json)
    {
        ErrorMessage = null;
        try
        {
            var pack = JsonSerializer.Deserialize<Pack>(json, JsonOptions);
            if (pack is null)
            {
                ErrorMessage = "Failed to parse the JSON file. The file may be empty or malformed.";
                return;
            }
            CurrentPack = pack;
            ShowSetup = false;
        }
        catch (JsonException ex)
        {
            ErrorMessage = $"Invalid JSON format: {ex.Message}";
            Console.WriteLine($"Error deserializing JSON: {ex.Message}");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load pack: {ex.Message}";
            Console.WriteLine($"Error loading pack: {ex.Message}");
        }
    }

    private async Task ConfirmStartFromScratch()
    {
        bool confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Are you sure? All unsaved changes will be lost!");
        if (confirmed)
        {
            ShowSetup = true;
            CurrentPack = null;
            ErrorMessage = null;
        }
    }

    private async Task DownloadPack()
    {
        if (CurrentPack is null) return;

        var exportOptions = new JsonSerializerOptions()
        {
            WriteIndented = true,
            Converters = { new ColorConverter() }
        };
        string json = JsonSerializer.Serialize(CurrentPack, exportOptions);
        Telemetry.DownloadPack(CurrentPack.Name);
        await JsRuntime.InvokeVoidAsync("downloadJson", json, CurrentPack.Name + ".json");
    }
}
